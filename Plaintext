[Unit]
Description=Bot Telegram InventarIAr - Orquestrador de Rede
After=network.target

[Service]
User=inventario
Group=inventario
WorkingDirectory=/home/inventario/telegram-bot-serv
# Adicione esta linha abaixo:
Environment=PYTHONPATH=/home/inventario/telegram-bot-serv
ExecStart=/home/inventario/automacao/py/myenv/bin/python3 /home/inventario/telegram-bot-serv/main.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target


